{
  "name": "@rxweave/llm",
  "version": "0.4.0",
  "description": "LLM-backed agents for RxWeave via Vercel AI SDK — tool calling, Effect Schema args, event emission.",
  "keywords": [
    "effect",
    "ai",
    "llm",
    "agents",
    "rxweave",
    "vercel-ai-sdk"
  ],
  "license": "MIT",
  "author": "Derek Wang",
  "homepage": "https://github.com/Derek-X-Wang/rxweave#readme",
  "bugs": {
    "url": "https://github.com/Derek-X-Wang/rxweave/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Derek-X-Wang/rxweave.git",
    "directory": "packages/llm"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22",
    "bun": ">=1.1"
  },
  "scripts": {
    "build": "bun build ./src/index.ts --target=node --format=esm --outdir=dist --splitting --packages=external && tsc --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "oxlint src test"
  },
  "dependencies": {
    "effect": "^3.21.0",
    "ai": "^5.0.0",
    "@rxweave/schema": "workspace:^",
    "@rxweave/runtime": "workspace:^"
  },
  "devDependencies": {
    "@effect/vitest": "^0.17.0",
    "@rxweave/core": "workspace:^",
    "@rxweave/store-memory": "workspace:^",
    "@types/node": "^22.10.0",
    "msw": "2.13.4",
    "typescript": "^5.5.4",
    "vitest": "^2.1.0"
  }
}
