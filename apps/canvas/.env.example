# Copy this file to `.env` and fill in your key. Bun picks up .env
# automatically when running from this directory (apps/canvas).
# .env is gitignored; .env.example is committed as a reference.

# One of the two LLM provider keys enables the suggester agent:
OPENROUTER_API_KEY=sk-or-...
# ANTHROPIC_API_KEY=sk-ant-...
